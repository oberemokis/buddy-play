{
  // Переопределение моделей для агентов.
  "agent_overrides": {
    "sisyphus": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "medium",
      "displayName": "Nexus",
      "description": "Central orchestrator. Plans, decomposes tasks, delegates to specialist agents, controls quality. Does not write code — ensures everything works together."
    },
    "hephaestus": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "high",
      "displayName": "Forge",
      "description": "Autonomous deep worker. Receives a goal, explores the codebase, researches patterns, and executes end-to-end without hand-holding."
    },
    "prometheus": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "max",
      "displayName": "Architect",
      "description": "Strategic planner. Interviews, clarifies requirements, and builds a detailed blueprint before a single line of code is touched."
    },
    "sisyphus-junior": {
      "model": "kimi-k2.6",
      "reasoningEffort": "medium",
      "displayName": "Drone",
      "description": "Focused executor. Receives an atomic task with clear boundaries and executes it. No planning, no delegation — pure execution."
    },
    "oracle": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "max",
      "displayName": "Oracle",
      "description": "Read-only consultant. Handles complex system architecture, finds root causes of bugs, provides high-IQ reasoning on hard problems."
    },
    "metis": {
      "displayName": "Scanner",
      "description": "Pre-planning analyst. Scans requests before planning to identify hidden intentions, ambiguities, and potential AI failure points."
    },
    "momus": {
      "displayName": "Audit",
      "description": "Plan and quality critic. Evaluates work plans and results against clarity, verifiability, and completeness standards. Ruthless with gaps."
    },
    "explore": {
      "displayName": "Scout",
      "description": "Fast codebase grep. Answers: where is X? which file has Y? find the code that does Z. Lightweight and parallel."
    },
    "librarian": {
      "displayName": "Archive",
      "description": "External knowledge search. Searches documentation, GitHub, and web for library usage examples, best practices, and API references."
    }
  },

  // Переопределение категорий Sisyphus-Junior.
  "categories": {
    // ★★★★★ Сложная логика, архитектура.
    "ultrabrain": {
      "model": "opencode/deepseek-v4-pro",
      "reasoningEffort": "max"
    },

    // ★★★★ Автономное исследование, комплексные задачи.
    "deep": {
      "model": "kimi-k2.7",
      "reasoningEffort": "high"
    },

    // ★★★★ Креативные, нестандартные решения.
    "artistry": {
      "model": "minmax-m3",
      "reasoningEffort": "medium"
    },

    // ★★★ UI/UX, стили, фронтенд.
    "visual-engineering": {
      "model": "minmax-m3",
      "reasoningEffort": "low"
    },

    // ★★★ Средние задачи без категории.
    "unspecified-high": {
      "model": "kimi-k2.6",
      "reasoningEffort": "medium"
    },

    // ★★ Документация, проза, техрайтинг.
    "writing": {
      "model": "glm-5.2",
      "reasoningEffort": "minimal"
    },

    // ★ Простые задачи без категории.
    "unspecified-low": {
      "model": "glm-5.2",
      "reasoningEffort": "minimal"
    },

    // ★ Опечатки, мелкие правки, один файл.
    "quick": {
      "model": "kimi-k2.6",
      "reasoningEffort": "none"
    }
  }
}
