{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode/deepseek-v4-pro",
  "instructions": [".rules"],
  "plugin": [
    "oh-my-openagent",
    "opencode-background-agents"
  ],
  "agent": {
    "committer": {
      "mode": "subagent",
      "model": "opencode/kimi-k2.5",
      "description": "Делает git-коммиты по правилам проекта. Не пушит и не редактирует файлы.",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  }
}
